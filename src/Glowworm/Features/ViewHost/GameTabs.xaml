<UserControl x:Class="Glowworm.Features.ViewHost.GameTabs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Glowworm.Language"
             xmlns:local="using:Glowworm.Features.ViewHost"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Height="48">
        <ItemsControl x:Name="ItemsControl_GameTabs" ItemsSource="{x:Bind GameList}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,0"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:GameTabItem">
                    <Button Click="Button_GameTab_Click" 
                            Padding="12,0,8,0" 
                            Height="32" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Left"
                            Style="{ThemeResource DefaultButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image Source="{x:Bind Icon}" Width="16" Height="16"/>
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                            <DropDownButton x:Name="Button_SwitchRegion" 
                                            Width="24" 
                                            Height="24" 
                                            Padding="-8,0,6,0" 
                                            BorderThickness="0"
                                            Background="Transparent"
                                            HorizontalAlignment="Left"
                                            Loaded="Button_SwitchRegion_Loaded">
                                <DropDownButton.Flyout>
                                    <MenuFlyout x:Name="MenuFlyout_Regions" Placement="Bottom">
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
