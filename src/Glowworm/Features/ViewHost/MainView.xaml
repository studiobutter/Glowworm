<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="Glowworm.Features.ViewHost.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Glowworm.Language"
             xmlns:local="using:Glowworm.Features.ViewHost"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <local:GameTabs x:Name="GameTabs_Main"
                        Grid.Row="0"
                        Margin="12,4,0,0" />

        <Border Name="Border_OverlayMask"
                Grid.Row="1"
                Background="Transparent"
                Opacity="0">
            <Border.OpacityTransition>
                <ScalarTransition />
            </Border.OpacityTransition>
        </Border>


        <NavigationView Name="MainView_NavigationView"
                        Grid.Row="1"
                        CompactPaneLength="56"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        ItemInvoked="NavigationView_ItemInvoked"
                        PaneDisplayMode="LeftCompact">
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <!--<Thickness x:Key="NavigationViewContentMargin">0,48,0,0</Thickness>-->
            </NavigationView.Resources>

            <NavigationView.MenuItems>
                <!--  ????  -->
                <NavigationViewItem Name="NavigationViewItem_Screenshot"
                                    Tag="ScreenshotPage"
                                    ToolTipService.ToolTip="{x:Bind lang:Lang.MainPage_GameScreenshot}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE91B;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <Border Height="40">
                            <TextBlock VerticalAlignment="Center" Text="{x:Bind lang:Lang.MainPage_GameScreenshot}" />
                        </Border>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <!--  ????  -->
                <NavigationViewItem Name="NavigationViewItem_GachaLog" Tag="GachaLogPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF4A5;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <Border Height="40">
                            <TextBlock x:Name="TextBlock_GachaLog" VerticalAlignment="Center" />
                        </Border>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <!--  ??????  -->
                <NavigationViewItem Name="NavigationViewItem_GenshinBeyondGacha"
                                    Tag="GenshinBeyondGachaPage"
                                    ToolTipService.ToolTip="{x:Bind lang:Lang.GenshinBeyondGachaPage_MiliastraWonderlandOde}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE776;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <Border Height="40">
                            <TextBlock VerticalAlignment="Center" Text="{x:Bind lang:Lang.GenshinBeyondGachaPage_MiliastraWonderlandOde}" />
                        </Border>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <!-- Miliastra Profile Pictures -->
                <NavigationViewItem Name="NavigationViewItem_BeyondProfilePicture"
                                    Tag="BeyondProfilePicturePage"
                                    ToolTipService.ToolTip="{x:Bind lang:Lang.BeyondProfilePicturePage_MiliastraProfilePictures}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <Border Height="40">
                            <TextBlock VerticalAlignment="Center" Text="{x:Bind lang:Lang.BeyondProfilePicturePage_MiliastraProfilePictures}" />
                        </Border>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame Name="MainView_Frame" Margin="0,0,0,0" />

        </NavigationView>



    </Grid>

</UserControl>



