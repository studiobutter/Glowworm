<?xml version="1.0" encoding="utf-8" ?>
<sf:WindowEx x:Class="Glowworm.Features.ViewHost.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Glowworm.Features.ViewHost"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mxi="using:Microsoft.Xaml.Interactivity"
             xmlns:sf="using:Glowworm.Frameworks"
             xmlns:sh="using:Glowworm.Helpers"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <Grid Background="Transparent">

        <local:MainView x:Name="MainContentHost"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />

        <StackPanel MaxWidth="600"
                    Margin="24,72,24,72"
                    VerticalAlignment="Bottom">
            <StackPanel.Transitions>
                <TransitionCollection>
                    <AddDeleteThemeTransition />
                </TransitionCollection>
            </StackPanel.Transitions>
            <mxi:Interaction.Behaviors>
                <sh:InAppToast Tag="MainWindow" />
            </mxi:Interaction.Behaviors>
        </StackPanel>

    </Grid>

</sf:WindowEx>



