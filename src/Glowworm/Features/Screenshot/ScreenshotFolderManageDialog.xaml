<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="Glowworm.Features.Screenshot.ScreenshotFolderManageDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:lang="using:Glowworm.Language"
               xmlns:local="using:Glowworm.Features.Screenshot"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               x:DefaultBindMode="OneWay"
               Background="{ThemeResource CustomAcrylicBrush}"
               BorderThickness="0"
               CornerRadius="8"
               Style="{ThemeResource DefaultContentDialogStyle}"
               mc:Ignorable="d">


    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1200</x:Double>
        <Thickness x:Key="ContentDialogPadding">0</Thickness>
        <StaticResource x:Key="ContentDialogSmokeFill" ResourceKey="ControlFillColorTransparentBrush" />
        <StaticResource x:Key="ContentDialogTopOverlay" ResourceKey="ControlFillColorTransparentBrush" />
    </ContentDialog.Resources>


    <Grid Width="600"
          MinHeight="240"
          MaxHeight="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <TextBlock Margin="24,24,0,12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="{x:Bind lang:Lang.ScreenshotFolderManageDialog_ImagesFromTheFollowingFoldersWillBeDisplayedInTheGallery}"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="1" Margin="24,0,24,12" Visibility="{x:Bind CloudFolderVisibility}">
            <TextBlock Margin="0,0,0,8" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind lang:Lang.CloudGameButton_CloudGame}" />
            <Grid ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="32" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind CloudFolder}"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Click="Button_OpenCloudFolder_Click"
                        Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="{x:Bind lang:Lang.Common_Open}">
                    <FontIcon FontSize="16"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Glyph="&#xE8A7;" />
                </Button>
                <Button Grid.Column="2"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Click="Button_BackupCloudFolder_Click"
                        Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                        ToolTipService.ToolTip="{x:Bind lang:Lang.ScreenshotPage_BackupScreenshots}">
                    <FontIcon FontSize="16"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Glyph="&#xF413;" />
                </Button>
            </Grid>
        </StackPanel>


        <MenuFlyoutSeparator Grid.Row="2" Margin="24,0,24,0" />


        <ListView Grid.Row="3"
                  Padding="12,0,12,0"
                  ItemsSource="{x:Bind ScreenshotFolders}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ScreenshotFolder">
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="32" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{x:Bind Folder}"
                                   TextWrapping="Wrap" />
                        <Button x:Name="Button_OpenFolder"
                                Grid.Column="1"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Click="Button_OpenFolder_Click"
                                Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                                ToolTipService.ToolTip="{x:Bind lang:Lang.Common_Open}">
                            <FontIcon FontSize="16"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Glyph="&#xE8A7;" />
                        </Button>
                        <!--  ?????  -->
                        <Button x:Name="Button_RemoveFolder"
                                Grid.Column="2"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Click="Button_RemoveFolder_Click"
                                Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                                ToolTipService.ToolTip="{x:Bind lang:Lang.Common_Remove}"
                                Visibility="{x:Bind CanRemove}">
                            <FontIcon FontSize="16"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Glyph="&#xE711;" />
                        </Button>
                        <!--  ?????  -->
                        <Button x:Name="Button_BackupFolder"
                                Grid.Column="2"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Click="Button_BackupFolder_Click"
                                Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                                ToolTipService.ToolTip="{x:Bind lang:Lang.ScreenshotPage_BackupScreenshots}"
                                Visibility="{x:Bind InGame}">
                            <FontIcon FontSize="16"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Glyph="&#xF413;" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--  ???  -->
        <StackPanel x:Name="StackPanel_BackingUp"
                    Grid.Row="4"
                    Margin="24,12,24,0"
                    Orientation="Horizontal"
                    Spacing="12"
                    Visibility="Collapsed">
            <ProgressRing Width="16"
                          Height="16"
                          IsIndeterminate="True" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                       Text="{x:Bind lang:Lang.ScreenshotFolderManageDialog_BackingUp}" />
        </StackPanel>

        <!--  ????  -->
        <TextBlock x:Name="TextBlock_BackupResult"
                   Grid.Row="4"
                   Margin="24,12,24,0"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />


        <!--  ?????  -->
        <Button Grid.Row="5"
                Margin="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Command="{x:Bind AddFolderCommand}">
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind lang:Lang.ScreenshotFolderManageDialog_AddFolder}" />
        </Button>


        <!--  ?? / ??  -->
        <StackPanel Grid.Row="5"
                    Margin="24"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="12">
            <Button Command="{x:Bind SaveCommand}"
                    Content="{x:Bind lang:Lang.Common_Save}"
                    IsEnabled="{x:Bind CanSave}"
                    Style="{ThemeResource AccentButtonStyle}" />
            <Button Command="{x:Bind CancelCommand}" Content="{x:Bind lang:Lang.Common_Cancel}" />
        </StackPanel>


    </Grid>


</ContentDialog>



