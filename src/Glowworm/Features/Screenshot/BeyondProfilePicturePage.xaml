<sf:PageBase x:Class="Glowworm.Features.Screenshot.BeyondProfilePicturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Glowworm.Language"
             xmlns:local="using:Glowworm.Features.Screenshot"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mxi="using:Microsoft.Xaml.Interactivity"
             xmlns:s="using:Glowworm"
             xmlns:sc="using:Glowworm.Controls"
             xmlns:sf="using:Glowworm.Frameworks"
             xmlns:ui="using:CommunityToolkit.WinUI"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBlock Margin="24,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="{x:Bind lang:Lang.BeyondProfilePicturePage_MiliastraProfilePictures}" />

        <StackPanel Margin="0,0,38,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="16">
            <Button Command="{x:Bind GetProfilePicturesCommand}" Content="{x:Bind lang:Lang.BeyondProfilePicturePage_GetProfilePictures}" />
        </StackPanel>

        <StackPanel Name="StackPanel_EmptyState"
                    Grid.RowSpan="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    Visibility="Collapsed">
            <Image Name="Image_Emoji"
                   Width="160"
                   Height="160" />
            <TextBlock HorizontalAlignment="Center"
                       FontSize="16"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.BeyondProfilePicturePage_NoImage}" />
            <Button HorizontalAlignment="Center" Command="{x:Bind GetProfilePicturesCommand}" Content="{x:Bind lang:Lang.BeyondProfilePicturePage_GetProfilePictures}" />
        </StackPanel>

        <ItemsView x:Name="ItemsView_Images"
                   Grid.Row="1"
                   Padding="24,0,0,12"
                   IsItemInvokedEnabled="True"
                   ItemInvoked="ItemsView_Images_ItemInvoked"
                   ItemsSource="{x:Bind ProfilePictures}"
                   SelectionMode="None">
            <ItemsView.Layout>
                <UniformGridLayout MinColumnSpacing="12"
                                   MinItemHeight="200"
                                   MinItemWidth="200"
                                   MinRowSpacing="12" />
            </ItemsView.Layout>
            <ItemsView.ItemTemplate>
                <DataTemplate x:DataType="local:ScreenshotItem">
                    <ItemContainer>
                        <Grid Name="Grid_ImageItem"
                              CanDrag="{x:Bind s:AppConfig.IsAdmin, Converter={StaticResource BoolReversedConverter}}"
                              DragStarting="Grid_ImageItem_DragStarting"
                              ui:UIElementExtensions.ClipToBounds="True"
                              CornerRadius="4"
                              DataContext="{x:Bind}">
                            <sc:CachedImage Name="Image_Thumb"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource ControlAltFillColorTertiaryBrush}"
                                            Source="{x:Bind FilePath}"
                                            Stretch="UniformToFill"
                                            CornerRadius="30"/>
                            
                            <StackPanel Name="StackPanel_Actions"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Background="#60000000"
                                        Opacity="0"
                                        Padding="4">
                                <Button Name="Button_CopyImage"
                                        Height="28"
                                        MinWidth="32"
                                        Padding="0"
                                        Margin="0,0,4,0"
                                        ToolTipService.ToolTip="{x:Bind lang:Lang.Common_Copy}"
                                        Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                                        Tapped="Button_CopyImage_Tapped">
                                    <FontIcon FontSize="16" Glyph="&#xE8C8;" Foreground="White" />
                                </Button>
                                <Button Name="Button_SaveAs"
                                        Height="28"
                                        MinWidth="32"
                                        Padding="0"
                                        Margin="0,0,4,0"
                                        ToolTipService.ToolTip="{x:Bind lang:Lang.BeyondProfilePicturePage_SaveAs}"
                                        Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                                        Tapped="Button_SaveAs_Tapped">
                                    <FontIcon FontSize="16" Glyph="&#xE792;" Foreground="White" />
                                </Button>
                            </StackPanel>
                            <Grid.Resources>
                                <CircleEase x:Key="CircleEase" EasingMode="EaseOut" />
                                <Storyboard x:Key="GridShowOnStoryboard">
                                    <DoubleAnimation EasingFunction="{StaticResource CircleEase}"
                                                     Storyboard.TargetName="StackPanel_Actions"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.6" />
                                </Storyboard>
                                <Storyboard x:Key="GridShowOffStoryboard">
                                    <DoubleAnimation EasingFunction="{StaticResource CircleEase}"
                                                     Storyboard.TargetName="StackPanel_Actions"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:1" />
                                </Storyboard>
                            </Grid.Resources>
                            <mxi:Interaction.Behaviors>
                                <mxi:EventTriggerBehavior EventName="PointerEntered">
                                    <mxi:ControlStoryboardAction Storyboard="{StaticResource GridShowOnStoryboard}" />
                                </mxi:EventTriggerBehavior>
                                <mxi:EventTriggerBehavior EventName="PointerExited">
                                    <mxi:ControlStoryboardAction Storyboard="{StaticResource GridShowOffStoryboard}" />
                                </mxi:EventTriggerBehavior>
                            </mxi:Interaction.Behaviors>
                        </Grid>
                    </ItemContainer>
                </DataTemplate>
            </ItemsView.ItemTemplate>
        </ItemsView>
    </Grid>
</sf:PageBase>