<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Glowworm.Features.Setting.AboutSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Glowworm.Language"
             xmlns:local="using:Glowworm.Features.Setting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:s="using:Glowworm"
             xmlns:sf="using:Glowworm.Frameworks"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel>

            <!--  Logo  -->
            <Image Width="160"
                   Height="160"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Source="ms-appx:///Assets/logo.png" />

            <TextBlock Margin="0,12,0,0"
                       FontSize="24"
                       FontWeight="Bold"
                       Text="{x:Bind lang:Lang.Common_Glowworm}" />
            <TextBlock Margin="0,4,0,0" Text="{x:Bind lang:Lang.AboutSettingPage_Description}" />


            <!--  ????  -->
            <StackPanel Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="4">
                <TextBlock Text="{x:Bind lang:Lang.SettingPage_CurrentVersion}" />
                <TextBlock FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           Text="{x:Bind s:AppConfig.AppVersion}" />
            </StackPanel>


            <!--  Update Source Selection  -->
            <StackPanel Margin="0,12,0,0" Spacing="4">
                <TextBlock Text="{x:Bind lang:Lang.SettingPage_UpdateSource}" />
                <ComboBox SelectedIndex="{x:Bind UpdateSource, Mode=TwoWay}">
                    <ComboBoxItem Content="GitHub" />
                    <ComboBoxItem Content="Cloudflare R2" />
                </ComboBox>
            </StackPanel>

            <!--  ?????  -->
            <ToggleSwitch Margin="0,12,0,0"
                          IsOn="{x:Bind EnablePreviewRelease, Mode=TwoWay}"
                          OffContent="{x:Bind lang:Lang.SettingPage_JoinPreviewReleaseChannel}"
                          OnContent="{x:Bind lang:Lang.SettingPage_JoinPreviewReleaseChannel}" />
            <Grid Margin="0,4,0,0" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!--  ????  -->
                <Button Height="40"
                        Padding="12,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind CheckUpdateCommand}"
                        CornerRadius="4,20,20,4"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE752;" />
                        <TextBlock Text="{x:Bind lang:Lang.SettingPage_CheckForUpdate}" />
                    </StackPanel>
                </Button>
                <!--  ??????  -->
                <TextBlock Grid.Column="1"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Visibility="{x:Bind LatestVersion, Converter={StaticResource ObjectToVisibilityConverter}}">
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind lang:Lang.AboutSetting_UpdatedToTheLatestVersion}" />
                    <Run Text="" />
                    <Run Foreground="{ThemeResource SystemFillColorSuccessBrush}" Text="{x:Bind LatestVersion}" />
                </TextBlock>
                <ProgressRing Grid.Column="1"
                              Width="20"
                              Height="20"
                              HorizontalAlignment="Left"
                              IsIndeterminate="{x:Bind CheckUpdateCommand.IsRunning}"
                              Visibility="{x:Bind CheckUpdateCommand.IsRunning}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind UpdateErrorText}"
                           TextWrapping="Wrap" />
            </Grid>


            <!--  ????  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="{x:Bind lang:Lang.AboutSettingPage_Links}" />
            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Left">
                <Hyperlink NavigateUri="https://github.com/studiobutter/Glowworm" UnderlineStyle="None">
                    <Run FontWeight="Bold"
                         Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                         Text="{x:Bind lang:Lang.SettingPage_ProjectHomepage}" />
                </Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Left">
                <Hyperlink NavigateUri="https://github.com/studiobutter/Glowworm/issues" UnderlineStyle="None">
                    <Run FontWeight="Bold"
                         Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                         Text="{x:Bind lang:Lang.SettingPage_ReportIssue}" />
                </Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Left">
                <Hyperlink NavigateUri="https://github.com/studiobutter/Glowworm/releases" UnderlineStyle="None">
                    <Run FontWeight="Bold"
                         Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                         Text="{x:Bind lang:Lang.SettingPage_ReleaseHistory}" />
                </Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Left">
                <Hyperlink NavigateUri="https://github.com/studiobutter/Glowworm/blob/main/docs/Privacy.md" UnderlineStyle="None">
                    <Run FontWeight="Bold"
                         Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                         Text="{x:Bind lang:Lang.SettingPage_PrivacyPolicy}" />
                </Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Left">
                <Hyperlink NavigateUri="https://ko-fi.com/studiobutterteam" UnderlineStyle="None">
                    <Run FontWeight="Bold"
                         Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                         Text="{x:Bind lang:Lang.SettingPage_Donate}" />
                </Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,8,0,20" HorizontalAlignment="Left">
                <Hyperlink NavigateUri="https://github.com/scighost/Starward" UnderlineStyle="None">
                <Run FontWeight="Bold"
                     Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                     Text="{x:Bind lang:Lang.SettingPage_OriginalProject}" />
                </Hyperlink>
            </TextBlock>




        </StackPanel>
    </ScrollViewer>

</sf:PageBase>



