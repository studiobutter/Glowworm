<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Glowworm.Features.Setting.FileManageSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Glowworm.Language"
             xmlns:local="using:Glowworm.Features.Setting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:s="using:Glowworm"
             xmlns:sf="using:Glowworm.Frameworks"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel>
            <TextBlock FontSize="20"
                       Text="{x:Bind lang:Lang.FileSettingPage_GameMgnt}"/>

            <TextBlock Margin="0,16,0,0"
                       FontSize="16"
                       Text="{x:Bind lang:Lang.FileSettingPage_HideCloudGames}"/>

            <TextBlock Margin="0,12,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.FileSettingPage_HideCloudGamesDesc}"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="16"
                        Margin="0,8,0,0">
                <ToggleSwitch IsOn="{x:Bind HideGenshinCloudChina, Mode=TwoWay}">
                    <ToggleSwitch.Header>
                        <TextBlock>
                            <Run Text="{x:Bind GenshinImpactText}"/>
                            <Run Text=" - "/>
                            <Run Text="{x:Bind ChinaCloudText}"/>
                        </TextBlock>
                    </ToggleSwitch.Header>
                </ToggleSwitch>
                <ToggleSwitch IsOn="{x:Bind HideStarRailCloudChina, Mode=TwoWay}">
                    <ToggleSwitch.Header>
                        <TextBlock>
                            <Run Text="{x:Bind HonkaiStarRailText}"/>
                            <Run Text=" - "/>
                            <Run Text="{x:Bind ChinaCloudText}"/>
                        </TextBlock>
                    </ToggleSwitch.Header>
                </ToggleSwitch>
            </StackPanel>

            <!--  Rescan Game Directories  -->
            <Button Height="40"
                    Margin="0,12,0,0"
                    Padding="16,0,16,0"
                    BorderThickness="0"
                    Command="{x:Bind RescanGameDirectoriesCommand}"
                    CornerRadius="8,20,20,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <FontIcon Glyph="&#xE72C;"/>
                    <TextBlock Text="{x:Bind lang:Lang.SettingPage_RescanGameDirectories}"/>
                </StackPanel>
            </Button>

            <MenuFlyoutSeparator Margin="0,20,0,12"/>

            <!--  ???????  -->
            <TextBlock FontSize="20"
                       Text="{x:Bind lang:Lang.FileSettingPage_DataFolder}"/>
            <TextBlock Margin="0,12,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.FileSettingPage_DataFolderIsImportant}"
                       TextWrapping="Wrap"/>
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!--  ????  -->
                <Button Grid.Column="0"
                        Height="40"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind ChangeUserDataFolderCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE8DE;"/>
                        <TextBlock Text="{x:Bind lang:Lang.SettingPage_ReselectDataFolder}"/>
                    </StackPanel>
                </Button>
                <!--  ?????????  -->
                <Button Grid.Column="1"
                        Height="40"
                        Margin="16,0,0,0"
                        Padding="20,0,20,1"
                        BorderThickness="0"
                        Command="{x:Bind OpenUserDataFolderCommand}"
                        CornerRadius="20">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   IsTextTrimmedChanged="TextBlock_IsTextTrimmedChanged"
                                   MaxLines="2"
                                   Text="{x:Bind s:AppConfig.UserDataFolder}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"/>
                        <FontIcon Grid.Column="1"
                                  Margin="0,2,2,0"
                                  FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Glyph="&#xE8A7;"/>
                    </Grid>
                </Button>
            </Grid>
            <!--  ??????  -->
            <Button Height="40"
                    Margin="0,8,0,0"
                    Padding="16,0,16,0"
                    BorderThickness="0"
                    Command="{x:Bind DeleteAllSettingCommand}"
                    CornerRadius="8,20,20,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <FontIcon Glyph="&#xE74D;"/>
                    <TextBlock Text="{x:Bind lang:Lang.SettingPage_DeleteAllSettings}"/>
                </StackPanel>
            </Button>

            <MenuFlyoutSeparator Margin="0,20,0,12"/>

            <!-- Backup Settings -->
            <TextBlock FontSize="20"
                       Text="{x:Bind lang:Lang.FileSettingPage_BackupSettings}"/>
            <TextBlock Margin="0,12,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.FileSettingPage_BackupDesc}"
                       TextWrapping="Wrap"/>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Height="40"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind ChangeBackupFolderCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE8DE;"/>
                        <TextBlock Text="{x:Bind lang:Lang.FileSettingPage_BackupSelectDir}"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1"
                        Height="40"
                        Margin="16,0,0,0"
                        Padding="20,0,20,0"
                        BorderThickness="0"
                        Command="{x:Bind OpenBackupFolderCommand}"
                        CornerRadius="20">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   IsTextTrimmedChanged="TextBlock_IsTextTrimmedChanged"
                                   MaxLines="2"
                                   Text="{x:Bind BackupFolderDisplay, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"/>
                        <FontIcon Grid.Column="1"
                                  Margin="0,2,2,0"
                                  FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Glyph="&#xE8A7;"/>
                    </Grid>
                </Button>
            </Grid>
            <!--  ?????  -->
            <StackPanel Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Spacing="16">
                <Button Height="40"
                        Margin="0,0,0,0"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind BackupDatabaseCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xF413;"/>
                        <TextBlock Text="{x:Bind lang:Lang.SettingPage_BackupDatabase}"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Height="40"
                        Margin="0,0,0,0"
                        Padding="12,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind RefreshBackupFolderNetworkStatusCommand}"
                        CornerRadius="20,20,20,20"
                        Visibility="{x:Bind ShowBackupFolderNetworkRefreshButton, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Margin="8,0,0,0"
                                  FontSize="16"
                                  Glyph="&#xE72C;"/>
                        <TextBlock Margin="6,0,0,0"
                                   Text="{x:Bind lang:Lang.Common_Refresh}"/>
                    </StackPanel>
                </Button>
                <ProgressRing Width="28"
                              Height="28"
                              IsIndeterminate="{x:Bind BackupDatabaseCommand.IsRunning}"
                              Visibility="{x:Bind BackupDatabaseCommand.IsRunning}"/>
                <Button Height="40"
                        Padding="20,0,20,1"
                        BorderThickness="0"
                        Command="{x:Bind OpenLastBackupDatabaseCommand}"
                        CornerRadius="20"
                        Visibility="{x:Bind LastDatabaseBackupTime, Converter={StaticResource ObjectToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{x:Bind LastDatabaseBackupTime}"/>
                        <FontIcon Margin="8,2,2,0"
                                  FontSize="16"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Glyph="&#xE8A7;"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <ToggleSwitch Margin="0,16,0,0"
                          IsOn="{x:Bind AutoBackupGachaRecord, Mode=TwoWay}">
                <ToggleSwitch.Header>
                    <TextBlock Text="{x:Bind lang:Lang.FileSettingPage_BackupAfterRecord}"/>
                </ToggleSwitch.Header>
            </ToggleSwitch>

            <TextBlock Margin="0,4,0,0"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       Visibility="{x:Bind IsBackupFolderNetworkDrive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                       Text="{x:Bind lang:Lang.FileSettingPage_BackupNetworkWarn}"
                       TextWrapping="Wrap"/>
            <TextBlock Margin="0,4,0,0"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       Visibility="{x:Bind IsBackupFolderCloudDrive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                       Text="{x:Bind lang:Lang.FileSettingPage_BackupCloudWarn}"
                       TextWrapping="Wrap"/>

            <CheckBox Margin="0,4,0,0"
                      IsEnabled="{x:Bind AutoBackupGachaRecord, Mode=OneWay}"
                      IsChecked="{x:Bind AutoBackupGachaRecordUIGF, Mode=TwoWay}"
                      Content="{x:Bind lang:Lang.FileSettingPage_AutoBackupUIGF}"/>

            <!--  ??  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="{x:Bind lang:Lang.FileSettingPage_Log}"/>
            <!--  ???????  -->
            <Button Height="40"
                    Margin="0,8,0,0"
                    Padding="16,0,16,0"
                    BorderThickness="0"
                    Command="{x:Bind OpenLogFolderCommand}"
                    CornerRadius="8,20,20,8"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <FontIcon Glyph="&#xE838;"/>
                    <TextBlock Text="{x:Bind lang:Lang.SettingPage_OpenLogFolder}"/>
                </StackPanel>
            </Button>


            <!--  ??  -->
            <TextBlock Margin="0,20,0,0"
                       FontSize="20"
                       Text="{x:Bind lang:Lang.FileSettingPage_Cache}"/>
            <StackPanel Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Spacing="20">
                <TextBlock>
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         Text="{x:Bind lang:Lang.FileSettingPage_Log}"/>
                    <LineBreak/>
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         Text="{x:Bind lang:Lang.FileSettingPage_Image}"/>
                    <LineBreak/>
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         Text="{x:Bind lang:Lang.FileSettingPage_Browser}"/>
                </TextBlock>
                <TextBlock>
                    <Run Text="{x:Bind LogCacheSize}"/>
                    <LineBreak/>
                    <Run Text="{x:Bind ImageCacheSize}"/>
                    <LineBreak/>
                    <Run Text="{x:Bind WebCacheSize}"/>
                    <LineBreak/>
                    <Run Text="{x:Bind GameCacheSize}"/>
                </TextBlock>
            </StackPanel>
            <!--  ????  -->
            <StackPanel Margin="0,12,0,12"
                        Orientation="Horizontal"
                        Spacing="16">
                <Button Height="40"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind ClearCacheCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xEA99;"/>
                        <TextBlock Text="{x:Bind lang:Lang.FileSettingPage_ClearCache}"/>
                    </StackPanel>
                </Button>
                <ProgressRing Width="28"
                              Height="28"
                              VerticalAlignment="Center"
                              IsIndeterminate="{x:Bind ClearCacheCommand.IsRunning}"
                              Visibility="{x:Bind ClearCacheCommand.IsRunning}"/>
            </StackPanel>



        </StackPanel>
    </ScrollViewer>

</sf:PageBase>



