<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Glowworm.Features.Setting.ScreenshotSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cwc="using:CommunityToolkit.WinUI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Glowworm.Language"
             xmlns:local="using:Glowworm.Features.Setting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Glowworm.Frameworks"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">


    <ScrollViewer Background="{x:Null}">
        <StackPanel Padding="0,0,24,24">

            <!--  ????  -->
            <TextBlock FontSize="20" Text="{x:Bind lang:Lang.BeyondProfilePicturePage_MiliastraProfilePictures}" />

            <!--  ??????????????????  -->
            <TextBlock Margin="0,12,0,0"
           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
           Text="{x:Bind lang:Lang.ScreenshotSetting_BeyondProfileLocationDesc}"
           TextWrapping="Wrap" />

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <!-- Change beyond folder -->
                <Button Grid.Column="0"
            Height="40"
            Padding="16,0,16,0"
            BorderThickness="0"
            Command="{x:Bind ChangeBeyondProfilePicturesFolderCommand}"
            CornerRadius="8,20,20,8"
            Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8DE;" />
                        <TextBlock Text="{x:Bind lang:Lang.Common_ChangeFolder}" />
                    </StackPanel>
                </Button>
                <!-- Open beyond folder -->
                <Button Grid.Column="1"
            Height="40"
            Margin="16,0,0,0"
            Padding="20,0,20,1"
            BorderThickness="0"
            Command="{x:Bind OpenBeyondProfilePicturesFolderCommand}"
            CornerRadius="20">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       IsTextTrimmedChanged="TextBlock_IsTextTrimmedChanged"
                       MaxLines="2"
                       Text="{x:Bind BeyondProfilePicturesFolder}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap" />
                        <FontIcon Grid.Column="1"
                      Margin="0,2,2,0"
                      FontSize="14"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      Glyph="&#xE8A7;" />
                    </Grid>
                </Button>
            </Grid>

            <MenuFlyoutSeparator Margin="0,20,0,0" />

            <!--  ????  -->
            <TextBlock Margin="0,12,0,0" FontSize="20" Text="{x:Bind lang:Lang.MainPage_GameScreenshot}" />

            <!--  ??????????????????  -->
            <TextBlock Margin="0,12,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.ScreenshotSetting_TheBuiltInScreenshotFeatureWillSaveImagesToTheFollowingFolder}"
                       TextWrapping="Wrap" />

            <!--  ?????  -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <!--  ???????  -->
                <Button Grid.Column="0"
                        Height="40"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind ChangeScreenshotFolderCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8DE;" />
                        <TextBlock Text="{x:Bind lang:Lang.Common_ChangeFolder}" />
                    </StackPanel>
                </Button>
                <!--  ???????  -->
                <Button Grid.Column="1"
                        Height="40"
                        Margin="16,0,0,0"
                        Padding="20,0,20,1"
                        BorderThickness="0"
                        Command="{x:Bind OpenScreenshotFolderCommand}"
                        CornerRadius="20">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   IsTextTrimmedChanged="TextBlock_IsTextTrimmedChanged"
                                   MaxLines="2"
                                   Text="{x:Bind ScreenshotFolder}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />
                        <FontIcon Grid.Column="1"
                                  Margin="0,2,2,0"
                                  FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Glyph="&#xE8A7;" />
                    </Grid>
                </Button>
            </Grid>

            <!--  ?????  -->
            <TextBlock Margin="0,16,0,0"
                       FontSize="20"
                       Text="{x:Bind lang:Lang.ScreenshotSetting_ScreenshotShortcut}" />

            <!--  ????????? (F1-F12),?????????? Glowworm,??????????????  -->
            <TextBlock Margin="0,8,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.HotkeySetting_SingleKeyShortcutsTips}"
                       TextWrapping="Wrap" />

            <!--  ?????  -->
            <local:HotkeyInput x:Name="HotkeyInput_ScreenshotCapture"
                               MinWidth="200"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Left"
                               HotkeyDeleted="HotkeyInput_HotkeyDeleted"
                               HotkeyEditFinished="HotkeyInput_HotkeyEditFinished"
                               HotkeyEditing="HotkeyInput_HotkeyEditing"
                               HotkeyId="44445"
                               WindowHandle="{x:Bind WindowHandle}" />


            <!--  ????  -->
            <TextBlock Margin="0,16,0,0"
                       FontSize="20"
                       Text="{x:Bind lang:Lang.ScreenshotSetting_OtherOptions}" />

            <!--  ???????  -->
            <StackPanel Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Spacing="12">
                <TextBlock VerticalAlignment="Center" Text="{x:Bind lang:Lang.ScreenshotSetting_FormatAndQuality}" />
                <cwc:Segmented x:Name="Segmented_ScreenshotFormat"
                               VerticalAlignment="Center"
                               SelectedIndex="{x:Bind ScreenshotForamt, Mode=TwoWay}">
                    <cwc:SegmentedItem MinWidth="80" Content="PNG" />
                    <cwc:SegmentedItem Content="AVIF" />
                    <cwc:SegmentedItem Content="JPEG XL" />
                </cwc:Segmented>
                <cwc:Segmented x:Name="Segmented_ScreenshotQuality"
                               VerticalAlignment="Center"
                               SelectedIndex="{x:Bind ScreenshotQuality, Mode=TwoWay}"
                               Visibility="{x:Bind ScreenshotQualityVisibility}">
                    <cwc:SegmentedItem MinWidth="80" Content="Medium" />
                    <cwc:SegmentedItem Content="High" />
                    <cwc:SegmentedItem Content="{x:Bind lang:Lang.ScreenshotSetting_Lossless}" />
                </cwc:Segmented>
            </StackPanel>

            <!--  ????????  -->
            <TextBlock Margin="0,6,0,0"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.ScreenshotSetting_HighQualityAVIFAndJPEGXLImageFormatsSaveApproximately85OfStorageSpace}"
                       TextWrapping="NoWrap" />


            <!--  ????????  -->
            <ToggleSwitch Margin="0,4,0,0"
                          IsOn="{x:Bind AutoCopyScreenshotToClipboard, Mode=TwoWay}"
                          OffContent="{x:Bind lang:Lang.ScreenshotSetting_AutoCopyScreenshotFile}"
                          OnContent="{x:Bind lang:Lang.ScreenshotSetting_AutoCopyScreenshotFile}" />

            <!--  ????? SDR ??  -->
            <ToggleSwitch Margin="0,-4,0,0"
                          IsOn="{x:Bind AutoConvertScreenshotToSDR, Mode=TwoWay}"
                          OffContent="{x:Bind lang:Lang.ScreenshotSetting_AutoConvertToSDRImage}"
                          OnContent="{x:Bind lang:Lang.ScreenshotSetting_AutoConvertToSDRImage}" />

            <!--  ????? HDR ??,????? SDR ???  -->
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.ScreenshotSetting_WhenCapturingHDRImagesSDRVersionWillAlsoBeSaved}"
                       TextWrapping="Wrap" />

            <StackPanel Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="12">
                <!--  ????  -->
                <Button Command="{x:Bind TestCaptureCommand}" Content="{x:Bind lang:Lang.ScreenshotSetting_TestScreenshot}" />
                <!--  ???????  -->
                <Button Command="{x:Bind ClearThumbnailCacheCommand}" Content="{x:Bind lang:Lang.ScreenshotSetting_ClearThumbnailCache}" />
            </StackPanel>

            <!--  ????  -->
            <TextBlock x:Name="TextBlock_CaptureError"
                       Margin="0,12,0,0"
                       Foreground="{ThemeResource SystemFillColorCautionBrush}"
                       Visibility="Collapsed" />

            <MenuFlyoutSeparator Margin="0,12,0,12" />

            <!--  ???????  -->
            <TextBlock FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.ScreenshotSetting_ScreenshotFetureDescAndLimit}"
                       TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>

</sf:PageBase>



