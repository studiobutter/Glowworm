<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Glowworm.Features.Setting.GeneralSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Glowworm.Language"
             xmlns:local="using:Glowworm.Features.Setting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Glowworm.Frameworks"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="0,0,24,0">


            <!--  General  -->
            <TextBlock FontSize="20" Text="{x:Bind lang:Lang.SettingPage_General}" />

            <ToggleSwitch x:Name="ToggleSwitch_RunInSystemTray"
                          Header="{x:Bind lang:Lang.SettingPage_RunInSystemTray}"
                          Margin="0,12,0,0"
                          Toggled="ToggleSwitch_RunInSystemTray_Toggled" />

            <!-- Language -->
            <TextBlock FontSize="20" Margin="0,20,0,0" Text="{x:Bind lang:Lang.SettingPage_Language}" />
            <ComboBox Name="ComboBox_Language"
                      Height="36"
                      MinWidth="260"
                      Margin="0,12,0,0"
                      Padding="18.5,0,0,0"
                      BorderThickness="0"
                      CornerRadius="8,18,18,8"
                      SelectionChanged="ComboBox_Language_SelectionChanged" />

            <!--  Help  -->
            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Left">
                <Hyperlink NavigateUri="https://github.com/studiobutter/Glowworm/blob/main/docs/Localization.md" UnderlineStyle="None">
                    <Run Text="{x:Bind lang:Lang.AppearanceSettingPage_HelpUsTranslateGlowworm}" />
                </Hyperlink>
            </TextBlock>


            <MenuFlyoutSeparator Margin="0,20,0,0" />

            <!-- Appearance -->
            <TextBlock FontSize="20" Margin="0,20,0,0" Text="{x:Bind lang:Lang.AppearanceSettingPage_TransparencyEffects}" />
            <ToggleSwitch x:Name="ToggleSwitch_Transparency"
                          Margin="0,12,0,0"
                          Toggled="ToggleSwitch_Transparency_Toggled" />

            <MenuFlyoutSeparator Margin="0,20,0,0" />

            <!--  System  -->
            <TextBlock Margin="0,20,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.SettingPage_ForABetterExperiencePleaseEnableTheFollowingFeaturesInSystemSettings}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Left">
                <Hyperlink Click="Hyperlink_VisualEffects_Click"
                           NavigateUri="ms-settings:easeofaccess-visualeffects"
                           UnderlineStyle="None">
                    <Run Text="{x:Bind lang:Lang.AppearanceSettingPage_TransparencyEffects}" />
                </Hyperlink>
                <Run Text=" " />
                <Hyperlink Click="Hyperlink_VisualEffects_Click"
                           NavigateUri="ms-settings:easeofaccess-visualeffects"
                           UnderlineStyle="None">
                    <Run Text="{x:Bind lang:Lang.AppearanceSettingPage_AnimationEffects}" />
                </Hyperlink>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>

</sf:PageBase>
